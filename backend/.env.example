# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (Supabase PostgreSQL for production OR SQLite for local development)
# For Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# For Local: sqlite:///./dev.db
DATABASE_URL=sqlite:///./dev.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Stable Diffusion (Replicate or Hugging Face)
REPLICATE_API_TOKEN=your-replicate-api-token

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=gourav@gmail.com
EMAIL_PASS=Gourav123
EMAIL_FROM="AI Boutique Studio <noreply@aiboutiquestudio.com>"

# Admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@123

# AI Credits Pricing
TRYON_CREDIT_COST=2
CHATBOT_CREDIT_COST=1
